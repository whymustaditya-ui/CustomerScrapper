# Mekari Qontak CRM — OAuth2 (client credentials)
# Copy this file to config/.env and fill in real values to activate the push module.
# While these are blank/absent, the Qontak push is a safe no-op that only logs payloads.

QONTAK_CLIENT_ID=
QONTAK_CLIENT_SECRET=
QONTAK_USERNAME=
QONTAK_PASSWORD=
QONTAK_BASE_URL=https://service-chat.qontak.com
QONTAK_AUTH_URL=https://service-chat.qontak.com/oauth/token

# Optional: Qontak contact list / segment id to push into (leave blank if not used)
QONTAK_CONTACT_LIST_ID=
