# Mekari Qontak CRM — OAuth2 (client credentials)
# Copy this file to config/.env and fill in real values to activate the push module.
# While these are blank/absent, the Qontak push is a safe no-op that only logs payloads.

QONTAK_CLIENT_ID=
QONTAK_CLIENT_SECRET=
QONTAK_USERNAME=
QONTAK_PASSWORD=
QONTAK_BASE_URL=https://service-chat.qontak.com
QONTAK_AUTH_URL=https://service-chat.qontak.com/oauth/token

# Optional: Qontak contact list / segment id to push into (leave blank if not used)
QONTAK_CONTACT_LIST_ID=

# --- Google Sheet CRM (Sales' living lead tracker) ---
# 1. Create a Google Cloud service account, download its JSON key.
# 2. Save the key (e.g. as config/service_account.json) and point to it below.
# 3. Create a Google Sheet, copy its id from the URL
#    (docs.google.com/spreadsheets/d/<THIS_PART>/edit), and share the sheet with
#    the service account's email (…@….iam.gserviceaccount.com) as Editor.
GSHEETS_CREDENTIALS_FILE=config/service_account.json
GSHEETS_SPREADSHEET_ID=
GSHEETS_WORKSHEET=CRM
